<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>SUPERMAD — Generator File Madrasah</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:linear-gradient(135deg,#063d35 0%,#0e7c6e 60%,#1a9080 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.card{background:#fff;border-radius:20px;padding:36px 40px;width:100%;max-width:580px;box-shadow:0 24px 80px rgba(0,0,0,.3)}
.logo{text-align:center;margin-bottom:28px}
.logo .icon{font-size:2.8rem;margin-bottom:8px}
.logo h1{font-size:1.45rem;font-weight:900;color:#0a3d33;letter-spacing:.02em}
.logo p{font-size:.78rem;color:#6b9e94;margin-top:5px}
.info{background:linear-gradient(90deg,#f0fdf4,#fff);border:1.5px solid #86efac;border-radius:10px;padding:12px 16px;font-size:.76rem;color:#166534;line-height:1.7;margin-bottom:22px}
.section-title{font-size:.72rem;font-weight:800;color:#4a6b63;text-transform:uppercase;letter-spacing:.08em;margin:18px 0 10px;display:flex;align-items:center;gap:6px}
.section-title::after{content:'';flex:1;height:1px;background:#e2ebe8}
.form-group{margin-bottom:13px}
label{display:block;font-size:.76rem;font-weight:700;color:#4a6b63;margin-bottom:5px}
label span{color:#dc2626}
input,select{width:100%;padding:9px 13px;border:1.5px solid #d0ddd9;border-radius:9px;font-size:.87rem;font-family:inherit;outline:none;transition:border-color .15s,box-shadow .15s}
input:focus,select:focus{border-color:#1a6b5c;box-shadow:0 0 0 3px rgba(26,107,92,.1)}
.row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.btn{width:100%;padding:13px;border-radius:10px;border:none;font-size:.95rem;font-weight:800;cursor:pointer;transition:all .15s;font-family:inherit;margin-top:10px;display:flex;align-items:center;justify-content:center;gap:8px}
.btn-generate{background:linear-gradient(90deg,#0a3d33,#1a6b5c);color:#fff}
.btn-generate:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,107,92,.35)}
.btn-generate:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.status{margin-top:14px;padding:13px 16px;border-radius:10px;font-size:.8rem;font-weight:600;display:none;text-align:center;line-height:1.6}
.status.ok{background:#f0fdf4;color:#166534;border:1.5px solid #86efac;display:block}
.status.err{background:#fef2f2;color:#991b1b;border:1.5px solid #fca5a5;display:block}
.lock-notice{display:flex;align-items:flex-start;gap:8px;background:#fffbeb;border:1px solid #fcd34d;border-radius:8px;padding:10px 12px;font-size:.73rem;color:#78350f;margin-top:14px;line-height:1.6}
.footer{margin-top:18px;text-align:center;font-size:.68rem;color:rgba(255,255,255,.4)}
@media(max-width:500px){.card{padding:24px 20px}.row{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="card">
  <div class="logo">
    <div class="icon">🏫</div>
    <h1>SUPERMAD — Generator</h1>
    <p>Buat file aplikasi supervisi yang terkunci untuk satu madrasah</p>
  </div>

  <div class="info">
    ℹ️ Isi data madrasah, klik <b>Generate &amp; Download</b>.<br>
    File langsung siap pakai — nama madrasah <b>terkunci permanen</b>.
  </div>

  <div class="section-title">🏫 Identitas Madrasah</div>

  <div class="form-group">
    <label>Nama Madrasah <span>*</span></label>
    <input type="text" id="nama" placeholder="Contoh: MAN 1 Banda Aceh" oninput="cekForm()">
  </div>
  <div class="row">
    <div class="form-group">
      <label>Tingkat <span>*</span></label>
      <select id="tingkat" onchange="cekForm()">
        <option value="">-- Pilih --</option>
        <option value="MI">MI (Madrasah Ibtidaiyah)</option>
        <option value="MTs">MTs (Madrasah Tsanawiyah)</option>
        <option value="MA">MA (Madrasah Aliyah)</option>
      </select>
    </div>
    <div class="form-group">
      <label>NPSN</label>
      <input type="text" id="npsn" placeholder="8 digit NPSN" maxlength="8">
    </div>
  </div>
  <div class="form-group">
    <label>Naungan / Instansi</label>
    <input type="text" id="naungan" placeholder="Contoh: Kementerian Agama Kab. Banda Aceh">
  </div>
  <div class="row">
    <div class="form-group">
      <label>Kabupaten / Kota</label>
      <input type="text" id="kotaKab" placeholder="Contoh: Banda Aceh">
    </div>
    <div class="form-group">
      <label>Provinsi</label>
      <input type="text" id="provinsi" placeholder="Contoh: Aceh">
    </div>
  </div>
  <div class="form-group">
    <label>Alamat Lengkap</label>
    <input type="text" id="alamat" placeholder="Jalan, No, Kelurahan/Desa">
  </div>

  <div class="section-title">📅 Tahun Ajaran &amp; Kepala Madrasah</div>

  <div class="row">
    <div class="form-group">
      <label>Tahun Ajaran <span>*</span></label>
      <select id="ta"><option value="2020/2021">2020/2021</option><option value="2021/2022">2021/2022</option><option value="2022/2023">2022/2023</option><option value="2023/2024">2023/2024</option><option value="2024/2025">2024/2025</option><option value="2025/2026" selected>2025/2026</option><option value="2026/2027">2026/2027</option><option value="2027/2028">2027/2028</option><option value="2028/2029">2028/2029</option><option value="2029/2030">2029/2030</option><option value="2030/2031">2030/2031</option><option value="2031/2032">2031/2032</option><option value="2032/2033">2032/2033</option><option value="2033/2034">2033/2034</option><option value="2034/2035">2034/2035</option><option value="2035/2036">2035/2036</option></select>
    </div>
    <div class="form-group">
      <label>Nama Kepala Madrasah</label>
      <input type="text" id="kepala" placeholder="Nama + gelar">
    </div>
  </div>
  <div class="form-group">
    <label>NIP Kepala Madrasah</label>
    <input type="text" id="nipKepala" placeholder="NIP kepala madrasah">
  </div>

  <div class="lock-notice">
    <span style="font-size:1rem;flex-shrink:0">🔒</span>
    <div><b>Perlindungan Permanen:</b> Setelah file diunduh, nama madrasah dikunci di dalam file dan tidak dapat diubah oleh siapapun.</div>
  </div>

  <button class="btn btn-generate" id="btnGen" onclick="generate()" disabled>
    <span id="btnIcon">📥</span>
    <span id="btnText">Generate &amp; Download File Madrasah</span>
  </button>
  <div class="status" id="status"></div>
</div>

<div class="footer">SUPERMAD &nbsp;·&nbsp; KMA 1503/2025 &nbsp;·&nbsp; Dirjenpendis 6077/2025</div>

<script>
var TPL_B64 = "";

function v(id){ return ((document.getElementById(id)||{}).value||'').trim(); }
function cekForm(){ document.getElementById('btnGen').disabled = !(v('nama').length>2 && v('tingkat')); }

function b64ToStr(b64){
  var bin = atob(b64);
  var bytes = new Uint8Array(bin.length);
  for(var i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i);
  return new TextDecoder('utf-8').decode(bytes);
}

function ea(s){ return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function generate(){
  var btn=document.getElementById('btnGen');
  var st=document.getElementById('status');
  btn.disabled=true;
  document.getElementById('btnIcon').textContent='⏳';
  document.getElementById('btnText').textContent='Sedang menyiapkan file...';
  st.className='status';

  setTimeout(function(){
    try {
      var mad = {
        nama:        v('nama'),
        tingkat:     v('tingkat'),
        tahunAjaran: v('ta'),
        kotaKab:     v('kotaKab'),
        provinsi:    v('provinsi'),
        namaKepala:  v('kepala'),
        nipKepala:   v('nipKepala'),
        alamat:      v('alamat'),
        npsn:        v('npsn'),
        naungan:     v('naungan')
      };

      var html = b64ToStr(TPL_B64);

      // Isi field profil
      html = html.replace(/(<input[^>]*id="profilNaungan"[^>]*)>/,
        '<input id="profilNaungan" value="'+ea(mad.naungan)+'" oninput="syncMadrasah()">');
      html = html.replace(/(<input[^>]*id="profilNamaMad"[^>]*)>/,
        '<input id="profilNamaMad" value="'+ea(mad.nama)+'" readonly '+
        'style="background:#f0f4f3;color:var(--text2);cursor:not-allowed;border-style:dashed" '+
        'title="Dikunci: '+ea(mad.nama)+'">');
      html = html.replace(/(<input[^>]*id="profilAlamat"[^>]*)>/,
        '<input id="profilAlamat" value="'+ea(mad.alamat)+'" oninput="syncMadrasah()">');
      html = html.replace(/(<input[^>]*id="profilKotaKab"[^>]*)>/,
        '<input id="profilKotaKab" value="'+ea(mad.kotaKab)+'" oninput="syncMadrasah()">');
      html = html.replace(/(<input[^>]*id="profilProvinsi"[^>]*)>/,
        '<input id="profilProvinsi" value="'+ea(mad.provinsi)+'">');
      html = html.replace(/(<input[^>]*id="profilNPSN"[^>]*)>/,
        '<input id="profilNPSN" value="'+ea(mad.npsn)+'">');
      html = html.replace(/(<input[^>]*id="profilNamaKepala"[^>]*)>/,
        '<input id="profilNamaKepala" value="'+ea(mad.namaKepala)+'">');
      html = html.replace(/(<input[^>]*id="profilNIPKepala"[^>]*)>/,
        '<input id="profilNIPKepala" value="'+ea(mad.nipKepala)+'">');

      // Set selected option untuk tingkat dan TA (hanya target <option> tags)
      html = html.replace(
        new RegExp('(<option[^>]*)value="'+mad.tingkat+'"','g'),
        '$1value="'+mad.tingkat+'" selected'
      );
      html = html.replace(
        new RegExp('(<option[^>]*)value="'+mad.tahunAjaran.replace(/\//g,'\\/').replace(/\./g,'\\.')+'"','g'),
        '$1value="'+mad.tahunAjaran+'" selected'
      );

      // Tampilkan label terkunci
      html = html.replace('id="namaMadLabel" style="display:none;','id="namaMadLabel" style="display:inline-flex;');
      html = html.replace('id="namaMadInfo" style="display:none;','id="namaMadInfo" style="display:block;');

      // Inject supermad-init via marker unik (aman dari SheetJS false positive)
      var initScript = '<scr'+'ipt id="supermad-init">(function(){'
        + 'var MK="supermad_profil",LK="supermad_namalock";'
        + 'var d='+JSON.stringify(mad)+';'
        + 'var ex=null;try{ex=JSON.parse(localStorage.getItem(MK));}catch(e){}'
        // Hanya hapus data jika nama madrasah BERBEDA
        + 'if(ex&&ex.nama&&ex.nama!==d.nama){'
        +   'localStorage.removeItem("supermad_v1");'
        +   'localStorage.removeItem("supermad_roster");'
        +   'localStorage.removeItem("supermad_draft");'
        + '}'
        // Set profil (nama selalu dikunci)
        + 'if(!ex||!ex.nama||ex.nama!==d.nama){localStorage.setItem(MK,JSON.stringify(d));}'
        + 'else{ex.nama=d.nama;ex.tingkat=d.tingkat;ex.npsn=d.npsn;ex.alamat=d.alamat;'
        +      'ex.kotaKab=d.kotaKab;ex.provinsi=d.provinsi;ex.naungan=d.naungan;'
        +      'localStorage.setItem(MK,JSON.stringify(ex));}'
        + 'localStorage.setItem(LK,"1");'
        + '})();<\/scr'+'ipt>';

      // Replace marker unik (bukan string </head> yang bisa ada di SheetJS)
      html = html.replace('<!--SUPERMAD-INIT-HERE-->', initScript);

      // Nama file
      var safe = mad.tingkat+'_'+mad.nama.replace(/[^a-zA-Z0-9]/g,'_').replace(/_+/g,'_').replace(/^_|_$/g,'');
      var ta   = mad.tahunAjaran.replace(/\//g,'-');
      var filename = 'SUPERMAD_'+safe+'_TA'+ta+'.html';

      // Download
      var blob = new Blob([html],{type:'text/html;charset=utf-8'});
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href=url; a.download=filename; a.style.display='none';
      document.body.appendChild(a); a.click();
      setTimeout(function(){document.body.removeChild(a);URL.revokeObjectURL(url);},800);

      document.getElementById('status').innerHTML =
        '✅ File <b>'+filename+'</b> berhasil diunduh!<br>'
        +'<span style="font-size:.74rem;color:#166534">🔒 Nama madrasah <b>'+ea(mad.nama)+'</b> terkunci permanen.</span>';
      document.getElementById('status').className='status ok';
      document.getElementById('btnIcon').textContent='✅';
      document.getElementById('btnText').textContent='Generate & Download File Madrasah';
      btn.disabled=false;

    } catch(err) {
      document.getElementById('status').textContent='❌ Error: '+err.message;
      document.getElementById('status').className='status err';
      document.getElementById('btnIcon').textContent='📥';
      document.getElementById('btnText').textContent='Generate & Download File Madrasah';
      btn.disabled=false;
    }
  }, 200);
}
</script>
</body>
</html>
